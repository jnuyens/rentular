{
  "name": "rentular",
  "version": "0.1.0",
  "private": true,
  "description": "OpenSource real estate management platform - payment follow-up, rent indexation, and tenant management",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rentular/rentular"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:studio": "pnpm --filter @rentular/db studio",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.2.0",
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
